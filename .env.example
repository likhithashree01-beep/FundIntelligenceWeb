# Vite reads VITE_*-prefixed vars and exposes them on `import.meta.env`.

# Backend base URL the frontend talks to.
# Leave empty for dev (the Vite proxy in vite.config.ts forwards /api/* to localhost:4000).
# Set this to the deployed backend URL for a production build, e.g.
#   VITE_API_BASE_URL=https://fund-intelligence-api.onrender.com
VITE_API_BASE_URL=

# Optional: change which backend the dev proxy targets (default http://localhost:4000).
# VITE_DEV_API_PROXY=http://localhost:4000
